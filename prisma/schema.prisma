generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// USER MANAGEMENT & RBAC
// ═══════════════════════════════════════════════════════════════

model Admin {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  name          String
  email         String   @unique
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  subscriptions Subscription[]
  notifications Notification[]

  @@map("admins")
}

model Teacher {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  name          String
  email         String   @unique
  phone         String?
  schoolName    String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  studentGroups StudentGroup[]
  subscription  Subscription?
  notifications Notification[]

  @@map("teachers")
}

model Student {
  id            String   @id @default(cuid())
  studentCode   String   @unique
  name          String
  grade         Int      // 6, 7, 8, 9
  section       String   // A, B, C, etc.
  academicYear  String   // "2025-2026"
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  studentGroup  StudentGroup? @relation(fields: [studentGroupId], references: [id])
  studentGroupId String?
  quizResults    QuizResultDB[]
  lessonProgress LessonProgress[]
  diagnosticResults DiagnosticResult[]

  @@map("students")
}

model StudentGroup {
  id          String   @id @default(cuid())
  name        String   // e.g., "Grade 6 - Section A"
  grade       Int
  section     String
  academicYear String
  teacherId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  teacher     Teacher   @relation(fields: [teacherId], references: [id])
  students    Student[]

  @@unique([grade, section, academicYear, teacherId])
  @@map("student_groups")
}

// ═══════════════════════════════════════════════════════════════
// SUBSCRIPTION & LICENSING
// ═══════════════════════════════════════════════════════════════

model Subscription {
  id              String   @id @default(cuid())
  teacherId       String   @unique
  adminId         String
  planType        String   @default("semester") // "semester"
  startDate       DateTime
  endDate         DateTime
  status          String   @default("active") // "active", "expired", "suspended", "renewed"
  studentCount    Int      @default(0)
  gradesCovered   String   @default("6,7,8,9") // comma-separated
  amount          Float    @default(0)
  currency        String   @default("AED")
  autoRenew       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  teacher         Teacher     @relation(fields: [teacherId], references: [id])
  admin           Admin       @relation(fields: [adminId], references: [id])
  notifications   Notification[]
  paymentHistory  PaymentRecord[]

  @@map("subscriptions")
}

model PaymentRecord {
  id              String   @id @default(cuid())
  subscriptionId  String
  amount          Float
  currency        String   @default("AED")
  paymentMethod   String?
  paymentStatus   String   @default("completed") // "pending", "completed", "failed", "refunded"
  transactionRef  String?
  description     String?
  createdAt       DateTime @default(now())

  subscription    Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("payment_records")
}

// ═══════════════════════════════════════════════════════════════
// NOTIFICATIONS SYSTEM
// ═══════════════════════════════════════════════════════════════

model Notification {
  id          String   @id @default(cuid())
  type        String   // "subscription_expiry", "system", "payment", "account"
  title       String
  message     String
  recipientType String // "admin", "teacher"
  recipientId String  // Admin or Teacher ID
  isRead      Boolean  @default(false)
  sentAt      DateTime @default(now())
  readAt      DateTime?

  // Optional relations
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId String?
  admin        Admin?        @relation(fields: [adminId], references: [id])
  adminId      String?
  teacher      Teacher?      @relation(fields: [teacherId], references: [id])
  teacherId    String?

  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════════
// ACADEMIC TRACKING
// ═══════════════════════════════════════════════════════════════

model QuizResultDB {
  id            String   @id @default(cuid())
  studentId     String
  lessonId      String
  grade         Int
  term          Int
  unit          String
  lessonTitle   String
  score         Int
  total         Int
  percentage    Float
  dokLevel      String
  domains       String
  assessmentType String  @default("formative") // "formative", "diagnostic", "summative"
  completedAt   DateTime @default(now())

  student       Student  @relation(fields: [studentId], references: [id])

  @@map("quiz_results")
}

model LessonProgress {
  id            String   @id @default(cuid())
  studentId     String
  lessonId      String
  grade         Int
  term          Int
  unit          String
  isCompleted   Boolean  @default(false)
  completedAt   DateTime?
  timeSpent     Int      @default(0) // seconds

  student       Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, lessonId])
  @@map("lesson_progress")
}

model DiagnosticResult {
  id            String   @id @default(cuid())
  studentId     String
  grade         Int
  term          Int
  score         Int
  total         Int
  percentage    Float
  results       String   // JSON string of detailed results
  completedAt   DateTime @default(now())

  student       Student  @relation(fields: [studentId], references: [id])

  @@map("diagnostic_results")
}

// ═══════════════════════════════════════════════════════════════
// SECURITY & AUDIT
// ═══════════════════════════════════════════════════════════════

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // "login", "logout", "create_user", "update_user", "delete_user", "subscription_create", etc.
  actorType   String   // "admin", "teacher", "student", "system"
  actorId     String?
  actorName   String?
  targetType  String?  // "admin", "teacher", "student", "subscription"
  targetId    String?
  details     String?  // JSON string with action details
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model LoginAttempt {
  id          String   @id @default(cuid())
  identifier  String   // username or email
  userType    String   // "admin", "teacher", "student"
  success     Boolean
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@map("login_attempts")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}
